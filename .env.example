# HTTP listen port (defaults to 8080)
PORT=8080

# Public base URL — must be reachable from GitHub.
# For local dev: ngrok / Cloudflare Tunnel / Tailscale Funnel.
BASE_URL=https://your-server.example.com

# sqlite path inside the container (volume-mounted)
STORE_DSN=file:/data/gharp.db?_pragma=journal_mode(WAL)

# Default runner image. ubuntu-noble carries common build tools; switch to
# `:latest` for the smaller default or pin a digest for reproducibility.
RUNNER_IMAGE=myoung34/github-runner:ubuntu-noble

# Global cap on simultaneously running ephemeral runners.
MAX_CONCURRENT_RUNNERS=4

# Optional: comma-separated label allowlist. A workflow_job is accepted
# if ANY of its `runs-on` labels appears here. Defaults to "self-hosted".
# To partition multiple gharp deployments, use a unique label per pool
# (e.g. "gpu-pool" on the GPU node, "cpu-pool" elsewhere). Sharing
# "self-hosted" between pools wouldn't isolate them — both would accept
# any self-hosted job.
# RUNNER_LABELS=self-hosted,gpu-pool

# Optional: GitHub API base. Override for GHES.
# GITHUB_API_BASE=https://gh.example.com/api/v3

# Optional: GitHub web base. Override for GHES (used to build runner repo
# URLs passed via {{.RepoURL}}).
# GITHUB_WEB_BASE=https://gh.example.com

# Optional: Docker daemon endpoint. Defaults to /var/run/docker.sock.
# DOCKER_HOST=tcp://docker:2375

# debug | info | warn | error
LOG_LEVEL=info

# RUNNER_COMMAND is a JSON array of argv (no shell). Required placeholders
# (startup-validated): {{.ContainerName}}, {{.RegistrationToken}},
# {{.RunnerName}}, {{.RepoURL}}, {{.Labels}}. Optional: {{.Image}}.
# Defaults to a minimal `docker run` (set in code). Override here to add
# things like socket mount, host network, workdir, or log rotation.
# Example:
# RUNNER_COMMAND=["docker","run","--rm","--name","{{.ContainerName}}","--network=host","-v","/var/run/docker.sock:/var/run/docker.sock","-v","/tmp/gharp/{{.ContainerName}}:/_work","-e","REPO_URL={{.RepoURL}}","-e","RUNNER_TOKEN={{.RegistrationToken}}","-e","RUNNER_NAME={{.RunnerName}}","-e","LABELS={{.Labels}}","-e","RUNNER_WORKDIR=/_work","-e","EPHEMERAL=1","{{.Image}}"]
